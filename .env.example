# docker-compose용 환경변수 예시 파일 — 복사해서 .env로 저장 후 값을 채우세요.
#   cp .env.example .env

# ---- 필수 ----
# TOTP 시크릿 암호화, 본인인증 DI 해시 등에 쓰이는 마스터 키. 값이 없으면 앱이 기동하지 않음.
# 생성: openssl rand -base64 32
APP_CRYPTO_SECRET_KEY=

# ---- DB (기본값 그대로 써도 되지만, 운영이라면 변경 권장) ----
DB_NAME=side
DB_USERNAME=side_app
DB_PASSWORD=side_app_pw
DB_ROOT_PASSWORD=changeme_root_pw

# ---- 서비스 ----
SERVER_PORT=15790
APP_BASE_URL=http://localhost:15790
SESSION_COOKIE_SECURE=false
ADMIN_BOOTSTRAP_PASSWORD=changeme123

# ---- 선택 연동 (비워두면 해당 기능만 개별 비활성화, README 참고) ----
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
KAKAO_CLIENT_ID=
PORTONE_STORE_ID=
PORTONE_CHANNEL_KEY=
PORTONE_API_SECRET=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=